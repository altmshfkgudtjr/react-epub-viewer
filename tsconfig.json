{
  "compilerOptions": {
    "target": "es2020",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "module": "esnext",
    "moduleResolution": "node",
    "declaration": true,
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "sourceMap": false,
    "jsx": "react-jsx",
    "baseUrl": "./src",
    "paths": {
      "modules": ["modules/index.ts"],
      "modules/*": ["modules/*"],
      "types": ["types/index.ts"],
      "types/*": ["types/*"],
      "lib/*": ["lib/*"],
      "LoadingView": ["LoadingView.tsx"]
    },
    "types": [
      "node",
      "vitest/globals"
    ]
  },
  "include": [
    "src"
  ]
}
